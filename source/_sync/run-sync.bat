@echo off
rem ============================================================
rem  run-sync.bat  —  더블클릭하면 팀즈 대화 수집을 1회 실행
rem  (실제 작업은 같은 폴더의 sync-teams-chat.ps1 이 한다)
rem ============================================================
chcp 65001 >nul
cd /d "%~dp0"

echo ============================================
echo   팀즈 대화 수집 시작
echo ============================================
echo.

powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0sync-teams-chat.ps1"

echo.
echo ============================================
echo   끝났습니다. 위 내용을 확인하고 창을 닫으세요.
echo ============================================
pause
