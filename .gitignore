# 재생성 가능한 yt-dlp 원본 스크랩 데이터 (약 694MB)
# 영상 메타(.info.json) + 자막 트랙(.json3) 원본. 가공 결과(자막 텍스트)는 유튜브_자막_모음/에 있음.
# 원본은 _압축본_백업/ 의 분할 압축본에 보존됨.
youtube-tools/raw/

# Node / 빌드 산출물 (app/ 및 루트 위임 빌드)
node_modules/
dist/

# Python 캐시
__pycache__/
*.pyc

# JPL 천체력 (절기표 재생성 시 skyfield가 자동 다운로드, 32MB)
dosa-app/engine/tools/de440s.bsp

# L2 파생 산출물 (정제본에서 extract_bodies.py로 재생성, 13.5MB)
dosa-app/kb/unit_bodies.json
dosa-app/kb/distill_src/

# 앱 KB 번들 (scripts/build_kb.mjs가 생성 — prebuild에서 자동)
app/public/kb.json
